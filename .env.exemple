# ============================================
# Confluences & Frontieres - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# === Application ===
PORT=3000

# === API Backend ===
# URL of the NestJS backend API
NEXT_PUBLIC_API_BASE=http://localhost:3000/api/v1/

# === Docker ===
# Project name for docker-compose (used as prefix for containers)
COMPOSE_PROJECT_NAME=confluences-et-frontieres
